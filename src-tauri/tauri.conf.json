{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "htmlbrowser.dev",
  "version": "0.1.0",
  "identifier": "dev.htmlbrowser.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1200,
        "height": 800,
        "minWidth": 720,
        "minHeight": 480,
        "transparent": true,
        "titleBarStyle": "Overlay",
        "trafficLightPosition": { "x": 20, "y": 29 },
        "windowEffects": {
          "effects": ["sidebar"],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Local-first viewer for AI-generated HTML artifacts",
    "longDescription": "htmlbrowser.dev is a lightweight desktop app for instantly previewing AI-generated HTML files, with live reload and isolated rendering.",
    "macOS": {
      "minimumSystemVersion": "11.0",
      "frameworks": [],
      "exceptionDomain": ""
    }
  }
}
